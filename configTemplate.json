{
  "playlists": {
    "queue_url": "https://open.spotify.com/playlist/your_queue_playlist_id",
    "downloaded_url": "https://open.spotify.com/playlist/your_downloaded_playlist_id"
  },
  "paths": {
    "music_root": "C:\\Users\\YourUsername\\Music"
  },
  "audio": {
    "extensions": [".mp3", ".flac", ".m4a", ".wav", ".ogg"]
  },
  "spotify": {
    "client_id": "your_client_id",
    "client_secret": "your_client_secret",
    "redirect_uri": "your_redirect_uri",
    "scope": ["playlist-modify-public"]
  }
}